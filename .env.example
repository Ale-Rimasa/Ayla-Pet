# ────────────────────────────────────────
# PROYECTO
# ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=PT Laser

# ────────────────────────────────────────
# SUPABASE
# ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Para conexión directa con psql / migraciones manuales (opcional)
DATABASE_URL=postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres

# ────────────────────────────────────────
# MERCADOPAGO (server-only — NO NEXT_PUBLIC_)
# ────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxx
MP_WEBHOOK_SECRET=xxxxx

# Opcional: solo si usás Checkout Bricks (pago embebido)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxx

# ────────────────────────────────────────
# EMAIL (Resend)
# ────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=ventas@ptlaser.com.ar

# ────────────────────────────────────────
# CONTACTO / WHATSAPP / SOCIAL
# ────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=5491100000000
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/ptlaser/

# ────────────────────────────────────────
# AMBIENTE
# ────────────────────────────────────────
NODE_ENV=development
