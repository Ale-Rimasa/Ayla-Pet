# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── MercadoPago ────────────────────────────────────────────────────────────
# Access token (APP_USR-...). MP ya no tiene sandbox: prod y test usan APP_USR-.
MP_ACCESS_TOKEN=
# REQUIRED en producción. Sin esto el HMAC del webhook es forjable.
MP_WEBHOOK_SECRET=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@example.com

# ─── Database (opcional) ────────────────────────────────────────────────────
DATABASE_URL=

# ─── Site / Branding ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://localhost:3000
NEXT_PUBLIC_SITE_NAME=Ayla
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your-handle
